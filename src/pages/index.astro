---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero-photo" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="container hero-body">
      <div class="hero-top-bar">
        <span class="label">9th Annual</span>
        <span class="label hero-date-label">Sept 6, 2026 · 1–5 PM</span>
      </div>

      <div class="hero-title-block">
        <h1 class="hero-title">
          <span class="title-maplewood">Maplewood</span>
          <span class="title-porchfest">Porchfest</span>
          <span class="title-year">2026</span>
        </h1>
      </div>

      <div class="hero-bottom-bar">
        <div class="hero-info-grid">
          <div class="hero-info-item">
            <span class="label">Date</span>
            <span>Sunday, September 6</span>
          </div>
          <div class="hero-info-item">
            <span class="label">Hours</span>
            <span>1:00 – 5:00 PM</span>
          </div>
          <div class="hero-info-item">
            <span class="label">Location</span>
            <span>Hilton Neighborhood, Maplewood NJ</span>
          </div>
          <div class="hero-info-item">
            <span class="label">Rain Date</span>
            <span>Monday, September 7</span>
          </div>
        </div>
        <div class="hero-ctas">
          <a href="/schedule" class="btn btn--primary">See the Schedule</a>
          <a href="/participate" class="btn btn--outline-light">Get Involved</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT THE EVENT ===================== -->
  <section class="section section--paper">
    <div class="container">
      <div class="event-desc-layout">
        <div class="event-desc-left">
          <span class="eyebrow" style="color: var(--red);">What is Porchfest?</span>
          <h2 class="event-desc-heading">A neighborhood<br/>becomes a stage</h2>
        </div>
        <div class="event-desc-right">
          <p>
            Maplewood Porchfest is a free afternoon of live music on the porches, stoops,
            yards, and driveways of the Hilton neighborhood. Every Labor Day Sunday. No tickets.
            No wristbands. No sponsors. Just music spilling into the street.
          </p>
          <p style="margin-top: 1rem;">
            Wander at your own pace. Follow the sound. Tip the performers. Talk to your neighbors.
          </p>
          <div class="event-desc-cta-row">
            <a href="/schedule" class="btn btn--outline-dark">Browse the Schedule</a>
            <a href="/#about" class="btn btn--outline-dark">About Porchfest</a>
          </div>
        </div>
      </div>

      <div class="event-photo-strip" aria-hidden="false">
        <img
          src="https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1S7A8628-FINAL-3200PX.jpg?format=2000w"
          alt="Live music performance at a Hilton neighborhood porch, Maplewood Porchfest"
          class="strip-photo"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ===================== HONK PARADE ===================== -->
  <section class="section section--ink">
    <div class="container honk-layout">
      <div class="honk-photo-col">
        <img
          src="https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/7583f04f-c0fb-4a40-8321-ae78b484eabb/Honk-A-Photo-Tom_Melee.jpg?format=1000w"
          alt="Honk Parade brass bands marching through the Hilton neighborhood"
          class="honk-photo"
          loading="lazy"
        />
      </div>
      <div class="honk-text-col">
        <span class="eyebrow" style="color: var(--yellow); opacity: 1;">Before the Music</span>
        <h2>Kick Off With the Honk Parade</h2>
        <div class="honk-rule"></div>
        <p>
          Gather at <strong>DeHart Community Center at 12 noon</strong> for the Honk Parade —
          a raucous procession of brass bands, cowbells, and neighbors winding through Hilton
          before the porches open.
        </p>
        <p style="margin-top: .85rem; opacity: .6; font-size: .9rem;">
          All are welcome. Bring an instrument. Bring yourself.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== STATS STRIP ===================== -->
  <section class="stats-strip section--red">
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-num">9th</span>
        <span class="stat-label label">Year</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">Free</span>
        <span class="stat-label label">Always free</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">30+</span>
        <span class="stat-label label">Performers</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">All<br/>Ages</span>
        <span class="stat-label label">Everyone welcome</span>
      </div>
      <div class="stats-cta">
        <a
          href="https://givebutter.com/maplewoodporchfest"
          class="btn btn--outline-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          Support Porchfest →
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section class="section section--paper" id="about">
    <div class="container about-layout">
      <div class="about-left">
        <span class="eyebrow" style="color: var(--red);">History</span>
        <h2>About<br/>Porchfest</h2>
      </div>
      <div class="about-right">
        <p>
          Maplewood Porchfest was founded by pianist <strong>Bill Tally</strong>, inspired
          by the Jamaica Plain Porchfest in Boston. What started as a small gathering of
          neighbors has grown into one of the area's most beloved annual traditions — now
          in its <strong>9th year</strong>.
        </p>
        <p style="margin-top: 1rem;">
          Presented by <a href="http://www.maplewoodcommunitymusic.org/" target="_blank" rel="noopener noreferrer" class="text-link">Maplewood Community Music</a>.
          Supported by the <a href="https://hnamaplewood.com/" target="_blank" rel="noopener noreferrer" class="text-link">Hilton Neighborhood Association</a>.
          Every performer, organizer, and volunteer gives their time freely.
          Performers pass the hat — tips go directly to the artists.
        </p>
        <div class="about-photo-pair">
          <img
            src="https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1S7A8932-final-FB+copy.jpg?format=800w"
            alt="Porch performance at Maplewood Porchfest"
            class="about-photo"
            loading="lazy"
          />
          <img
            src="https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/d8093de0-8eab-4c4d-be1a-f062532e5f10/Porchresters+at+the+very+first+Maplewood+Porchfest+in+2017+-+Photo+%C2%A9+Tracy+Sham+Photography.jpg?format=800w"
            alt="Porchresters at the very first Maplewood Porchfest in 2017"
            class="about-photo"
            loading="lazy"
          />
        </div>
        <p class="about-photo-caption">Left: 2024 · Right: First Porchfest, 2017 — Photo © Tracy Sham Photography</p>
      </div>
    </div>
  </section>

  <!-- ===================== INSTAGRAM ===================== -->
  <section class="section section--ink-mid instagram-section">
    <div class="container">
      <div class="instagram-header">
        <div>
          <span class="eyebrow" style="opacity: .45;">Social</span>
          <h2>@maplewood_<wbr/>porchfest</h2>
        </div>
        <a
          href="https://www.instagram.com/maplewood_porchfest/"
          class="btn btn--outline-light"
          target="_blank"
          rel="noopener noreferrer"
        >Follow on Instagram</a>
      </div>
      <div class="instagram-grid">
        {[
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1780188224915-IG9HY1T57DF7P4ECO49Q/image-asset.jpeg?format=500w" },
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1775889101981-H9SV0UTUFL80DKCWCQNQ/image-asset.jpeg?format=500w" },
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1775878816891-65G1F3FKWVFTCM0YYH3T/image-asset.jpeg?format=500w" },
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1775889101981-GS353DM8SOA10KA7UFRD/image-asset.jpeg?format=500w" },
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1775889101981-FF3UPU65CVAEYLQPE6NE/image-asset.jpeg?format=500w" },
          { url: "https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/1775889101981-XARZMHLCZWXAB20YLFBM/image-asset.jpeg?format=500w" },
        ].map(img => (
          <a
            href="https://www.instagram.com/maplewood_porchfest/"
            class="instagram-tile"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src={img.url} alt="@maplewood_porchfest on Instagram" loading="lazy" class="ig-img" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== GET INVOLVED ===================== -->
  <section class="section section--paper">
    <div class="container">
      <div class="get-involved-header">
        <span class="eyebrow" style="color: var(--red);">Three ways in</span>
        <h2>Get Involved</h2>
      </div>
      <div class="involved-grid">
        <a href="/participate" class="involved-card">
          <span class="involved-num label">01</span>
          <span class="involved-icon">🏡</span>
          <h3 class="involved-title">Porch</h3>
          <p>Hilton neighbors: lend your porch, steps, yard, or driveway for a set.</p>
        </a>
        <a href="/participate" class="involved-card involved-card--accent">
          <span class="involved-num label">02</span>
          <span class="involved-icon">🎤</span>
          <h3 class="involved-title">Perform</h3>
          <p>Musicians, DJs, poets, dancers — play a 45-min set and pass the hat.</p>
        </a>
        <a href="/participate" class="involved-card">
          <span class="involved-num label">03</span>
          <span class="involved-icon">🍋</span>
          <h3 class="involved-title">Volunteer</h3>
          <p>Help run the event, work a lemonade stand, or march in the Honk Parade.</p>
        </a>
      </div>
      <div class="involved-footer">
        <p style="color: var(--red); font-weight: 700; font-size: .85rem; max-width: 100%;">Registration forms open mid-June 2026.</p>
        <a href="/participate" class="btn btn--outline-dark">See all ways to participate →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: var(--ink);
  margin-top: -64px;
  padding-top: 64px;
  overflow: hidden;
}

.hero-photo {
  position: absolute;
  inset: 0;
  background-image: url('https://images.squarespace-cdn.com/content/v1/62c07123d4144621a5a33ba1/71b5c943-d5cc-4785-b1f5-2d41ef6e4ac4/IMG_6544-C.jpg?format=2500w');
  background-size: cover;
  background-position: center 25%;
  background-repeat: no-repeat;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  /* Duotone-style: heavy ink with a red warmth at the bottom */
  background:
    linear-gradient(
      to bottom,
      rgba(12,11,9,.72) 0%,
      rgba(12,11,9,.45) 40%,
      rgba(12,11,9,.78) 75%,
      rgba(12,11,9,.95) 100%
    ),
    linear-gradient(
      135deg,
      rgba(232,73,42,.15) 0%,
      transparent 60%
    );
}

.hero-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-bottom: 3.5rem;
}

/* Top bar */
.hero-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(239,231,210,.18);
  padding-bottom: 1rem;
  margin-bottom: 1.5rem;
  color: rgba(239,231,210,.5);
}
.hero-date-label { text-align: right; }

/* Title block — the festival bill moment */
.hero-title-block {
  padding-block: 1rem 2rem;
  border-bottom: 1px solid rgba(239,231,210,.18);
  margin-bottom: 2rem;
}

.hero-title {
  display: flex;
  flex-direction: column;
  line-height: .88;
  letter-spacing: -.02em;
  gap: 0;
}

.title-maplewood {
  font-family: var(--font-display);
  font-weight: 700;
  font-style: italic;
  font-size: clamp(2rem, 7vw, 5rem);
  text-transform: uppercase;
  color: rgba(239,231,210,.65);
  letter-spacing: .04em;
}

.title-porchfest {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  font-size: clamp(5rem, 18vw, 14rem);
  text-transform: uppercase;
  color: var(--paper);
  line-height: .85;
  letter-spacing: -.02em;
}

.title-year {
  font-family: var(--font-display);
  font-weight: 700;
  font-style: normal;
  font-size: clamp(1.4rem, 4vw, 3rem);
  text-transform: uppercase;
  color: var(--red);
  letter-spacing: .14em;
}

/* Bottom bar */
.hero-bottom-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.hero-info-grid {
  display: grid;
  grid-template-columns: repeat(4, auto);
  gap: .5rem 2.5rem;
}

.hero-info-item {
  display: flex;
  flex-direction: column;
  gap: .2rem;
}
.hero-info-item .label {
  color: rgba(239,231,210,.4);
  opacity: 1;
}
.hero-info-item span:last-child {
  font-family: var(--font-body);
  font-size: .88rem;
  font-weight: 600;
  color: var(--paper);
}

.hero-ctas {
  display: flex;
  gap: .75rem;
  flex-shrink: 0;
  flex-wrap: wrap;
}

/* ===== ABOUT THE EVENT ===== */
.event-desc-layout {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 5rem;
  align-items: start;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--paper-dark);
  margin-bottom: 2.5rem;
}

.event-desc-heading {
  color: var(--ink);
  line-height: .9;
  margin-top: .5rem;
}

.event-desc-right p {
  color: rgba(12,11,9,.7);
  font-size: 1.05rem;
}

.event-desc-cta-row {
  display: flex;
  gap: .75rem;
  margin-top: 2rem;
  flex-wrap: wrap;
}

.strip-photo {
  width: 100%;
  height: 420px;
  object-fit: cover;
  object-position: center 30%;
  display: block;
  filter: contrast(1.05) saturate(.95);
}

/* ===== HONK PARADE ===== */
.honk-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.honk-photo {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
  filter: contrast(1.05);
}

.honk-text-col h2 { margin-bottom: .75rem; line-height: .9; }
.honk-text-col p { color: rgba(239,231,210,.75); font-size: .95rem; }

.honk-rule {
  height: 2px;
  background: var(--red);
  width: 40px;
  margin-bottom: 1.25rem;
}

/* ===== STATS STRIP ===== */
.stats-strip { padding-block: 2.25rem; }

.stats-inner {
  display: flex;
  align-items: center;
  gap: 0;
  flex-wrap: wrap;
}

.stat {
  display: flex;
  flex-direction: column;
  gap: .25rem;
  padding: .5rem 2.5rem .5rem 0;
}

.stat-num {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--ink);
  line-height: 1;
  text-transform: uppercase;
}

.stat-label { color: rgba(12,11,9,.6); opacity: 1; }

.stat-divider {
  width: 1px;
  height: 48px;
  background: rgba(12,11,9,.2);
  margin-right: 2.5rem;
  flex-shrink: 0;
}

.stats-cta { margin-left: auto; }

/* ===== ABOUT ===== */
.about-layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}

.about-left h2 { color: var(--ink); line-height: .9; margin-top: .5rem; }

.about-right p { color: rgba(12,11,9,.7); }

.text-link {
  color: var(--red);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(232,73,42,.4);
  font-weight: 600;
  transition: text-decoration-color var(--transition);
}
.text-link:hover { text-decoration-color: var(--red); }

.about-photo-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .75rem;
  margin-top: 2rem;
}

.about-photo {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
  filter: contrast(1.02) saturate(.9);
}

.about-photo-caption {
  font-size: .72rem;
  color: rgba(12,11,9,.4);
  margin-top: .5rem;
  max-width: 100%;
  font-style: italic;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

/* ===== INSTAGRAM ===== */
.instagram-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.instagram-header h2 { line-height: .9; }

.instagram-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 3px;
}

.instagram-tile {
  display: block;
  aspect-ratio: 1;
  overflow: hidden;
  position: relative;
}

.ig-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 350ms ease, filter 350ms ease;
  filter: saturate(.85);
}
.instagram-tile:hover .ig-img {
  transform: scale(1.05);
  filter: saturate(1.1);
}

/* ===== GET INVOLVED ===== */
.get-involved-header {
  margin-bottom: 2.5rem;
}
.get-involved-header h2 { color: var(--ink); line-height: .9; margin-top: .4rem; }

.involved-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 2px solid var(--ink);
}

.involved-card {
  padding: 2.25rem 2rem;
  border-right: 2px solid var(--ink);
  display: flex;
  flex-direction: column;
  gap: .75rem;
  text-decoration: none;
  color: var(--ink);
  transition: background var(--transition), color var(--transition);
  position: relative;
}

.involved-card:last-child { border-right: none; }

.involved-card:hover {
  background: var(--ink);
  color: var(--paper);
}

.involved-card--accent {
  background: var(--red);
  color: var(--ink);
  border-right-color: var(--ink);
}
.involved-card--accent:hover {
  background: var(--red-dark);
  color: var(--paper);
}

.involved-num {
  color: inherit;
  opacity: .35;
}

.involved-icon { font-size: 1.75rem; }

.involved-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  text-transform: uppercase;
  font-size: 2rem;
  line-height: 1;
}

.involved-card p {
  font-size: .88rem;
  opacity: .7;
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

.involved-footer {
  margin-top: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .hero-info-grid { grid-template-columns: repeat(2, auto); }
}

@media (max-width: 900px) {
  .event-desc-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .strip-photo { height: 280px; }
  .honk-layout { grid-template-columns: 1fr; gap: 2rem; }
  .about-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .about-left { display: flex; align-items: baseline; gap: 1.5rem; }
  .instagram-grid { grid-template-columns: repeat(3, 1fr); }
  .involved-grid { grid-template-columns: 1fr; border-bottom: none; }
  .involved-card { border-right: none; border-bottom: 2px solid var(--ink); }
}

@media (max-width: 640px) {
  .hero-bottom-bar { flex-direction: column; align-items: flex-start; }
  .hero-info-grid { grid-template-columns: 1fr 1fr; gap: .75rem 2rem; }
  .hero-ctas { width: 100%; }
  .hero-ctas .btn { flex: 1; justify-content: center; }
  .title-porchfest { font-size: clamp(3.5rem, 22vw, 8rem); }
  .stats-inner { flex-direction: column; align-items: flex-start; gap: 0; }
  .stat { padding: .75rem 0; border-bottom: 1px solid rgba(12,11,9,.15); width: 100%; }
  .stat-divider { display: none; }
  .stats-cta { margin-left: 0; margin-top: 1.25rem; }
  .about-photo-pair { grid-template-columns: 1fr; }
  .instagram-grid { grid-template-columns: repeat(2, 1fr); }
  .involved-footer { flex-direction: column; align-items: flex-start; }
}
</style>
