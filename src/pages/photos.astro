---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const photos = [
  {
    src: "/images/honk-parade.jpg",
    caption: "The Honk Parade rolls through the Hilton neighborhood",
    credit: "Tom Melee",
    year: 2024,
    highlight: true,
  },
  {
    src: "/images/photos/crowd-lawn-2024.jpg",
    caption: "Crowds gather on the lawn for a porch performance",
    credit: "Gregory Burrus",
    year: 2024,
    highlight: true,
  },
  {
    src: "/images/photos/shaded-porch-2024.jpg",
    caption: "Full-swing performance at a shaded porch",
    credit: "John Munson",
    year: 2024,
    highlight: true,
  },
  {
    src: "/images/photos/golden-afternoon-2024.jpg",
    caption: "Golden afternoon light on a porch performance",
    credit: "John Munson",
    year: 2024,
    highlight: true,
  },
  {
    src: "/images/photos/band-energy-2024.jpg",
    caption: "Band bringing the energy to a backyard crowd",
    credit: "John Munson",
    year: 2024,
    highlight: false,
  },
  {
    src: "/images/photos/rites-of-springfield-2024.jpg",
    caption: "Rites of Springfield performing at Porchfest",
    credit: "John Munson",
    year: 2024,
    highlight: false,
  },
  {
    src: "/images/photos/street-crowd-2023.jpg",
    caption: "Musicians playing to an appreciative street crowd",
    credit: "Scott Kettner",
    year: 2023,
    highlight: true,
  },
  {
    src: "/images/photos/neighbor-audience-2023.jpg",
    caption: "Neighbor audience enjoying the street-side performance",
    credit: "Steve LeBlanc",
    year: 2023,
    highlight: true,
  },
  {
    src: "/images/photos/lemonade-stand-2022.jpg",
    caption: "The lemonade stand in action on a warm Porchfest afternoon",
    credit: "Tracy Sham",
    year: 2022,
    highlight: true,
  },
  {
    src: "/images/photos/young-fan-2021.jpg",
    caption: "A young Porchfest fan enjoys the music",
    credit: "Community volunteer",
    year: 2021,
    highlight: true,
  },
  {
    src: "/images/photos/porchresters-2017.jpg",
    caption: "The Porchresters at the very first Maplewood Porchfest, 2017",
    credit: "Tracy Sham Photography",
    year: 2017,
    highlight: true,
  },
];

const years = [2024, 2023, 2022, 2021, 2017];
---

<BaseLayout
  title="Photos"
  description="Browse photos from past Maplewood Porchfest events, captured by community photographers."
>

  <PageHero
    title="Photos"
    subtitle="Nine years of music, porches, and community — captured across Maplewood's Hilton neighborhood."
  />

  <section class="section">
    <div class="container">

      <div class="tab-strip" role="tablist">
        <button class="tab-btn active" data-tab="highlights" role="tab" aria-selected="true">Highlights</button>
        {years.map((year) => (
          <button class="tab-btn" data-tab={String(year)} role="tab" aria-selected="false">{year}</button>
        ))}
      </div>

      <div class="photo-grid">
        {photos.map((photo) => (
          <figure
            class="photo-card"
            data-year={String(photo.year)}
            data-highlight={photo.highlight ? "true" : "false"}
          >
            <div class="photo-img-wrap">
              <img
                src={photo.src}
                alt={photo.caption}
                class="photo-img"
                loading="lazy"
              />
            </div>
            <figcaption class="photo-caption">
              <p class="photo-desc">{photo.caption}</p>
              <p class="photo-meta">{photo.year} · {photo.credit}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <hr class="photo-divider" />

      <div class="photo-attribution">
        <h3>Photo Credits</h3>
        <p>
          Photographs by Tracy Sham Photography, Tom Melee, Gary Stein, Gregory Burrus, Eric Greenberg,
          Jamaine Cripe, Erin Scherzer, Mara Ebert, Mark Goldberg, Sarah Hood, Steve LeBlanc,
          Lauren Sullivan, Bari Epstein, Don Charles, Claire Sinclair, Kelly Heinze, David Kay,
          Scott Kettner, Larry Seltzer, and Janet Painter.
          All images &copy; their respective photographers. Used with permission.
          To submit photos or inquire about usage rights, please
          <a href="/contact" class="text-link">contact us</a>.
        </p>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const cards = document.querySelectorAll<HTMLElement>('.photo-card');

  function activate(tab: string) {
    tabs.forEach(btn => {
      const active = btn.dataset.tab === tab;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    cards.forEach(card => {
      let visible = false;
      if (tab === 'highlights') {
        visible = card.dataset.highlight === 'true';
      } else {
        visible = card.dataset.year === tab;
      }
      card.style.display = visible ? '' : 'none';
    });
  }

  tabs.forEach(btn => {
    btn.addEventListener('click', () => activate(btn.dataset.tab!));
  });

  activate('highlights');
</script>

<style>
.tab-strip {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  margin-bottom: 1.75rem;
}

.tab-strip .tab-btn {
  font-family: var(--font-body);
  font-size: .875rem;
  font-weight: 600;
  padding: .4rem 1.1rem;
  border-radius: 50px;
  border: 1.5px solid var(--cream-dark);
  background: var(--white);
  color: var(--charcoal);
  cursor: pointer;
  transition: background var(--transition), color var(--transition), border-color var(--transition);
}

.tab-strip .tab-btn:hover:not(.active) {
  border-color: var(--green);
  color: var(--green);
}

.tab-strip .tab-btn.active {
  background: var(--green);
  color: var(--white);
  border-color: var(--green);
}

.photo-grid {
  column-count: 3;
  column-gap: 1.5rem;
}

.photo-card {
  break-inside: avoid;
  margin-bottom: 2rem;
}

.photo-img-wrap {
  background: var(--cream-dark);
}

.photo-img {
  width: 100%;
  height: auto;
  display: block;
}

.photo-caption {
  padding: .6rem 0 0;
}

.photo-desc {
  font-size: .85rem;
  color: var(--charcoal);
  margin-bottom: .25rem;
  line-height: 1.4;
}

.photo-meta {
  font-size: .75rem;
  color: var(--gray-light);
}

.photo-divider {
  border: none;
  border-top: 1px solid var(--cream-dark);
  margin: 3rem 0 2rem;
}

.photo-attribution h3 {
  font-size: 1rem;
  margin-bottom: .5rem;
}

.photo-attribution p {
  font-size: .9rem;
  color: var(--gray);
  max-width: 70ch;
}

.text-link {
  color: var(--green);
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 600;
}
.text-link:hover { color: var(--green-light); }

@media (max-width: 900px) {
  .photo-grid { column-count: 2; }
}

@media (max-width: 600px) {
  .photo-grid { column-count: 1; }
}

@media print {
  .photo-grid { column-count: 2; }
  .tab-strip { display: none; }
}
</style>
