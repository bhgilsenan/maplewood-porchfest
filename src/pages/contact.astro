---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with the Maplewood Porchfest team."
>

  <PageHero
    title="Contact"
    subtitle="For porch, performer, or volunteer inquiries, visit the Participate page. For everything else, use the form below."
  />

  <section class="section section--paper">
    <div class="container contact-layout">

      <div class="contact-form-col">
        <span class="eyebrow" style="color: var(--red);">Send a message</span>
        <h2 class="contact-heading">We'll get back<br/>to you</h2>
        <p class="contact-note">
          Please allow 48 hours for a response. Registration inquiries open
          via the <a href="/participate" class="form-link">Participate page</a> in mid-June.
        </p>

        <form class="contact-form" action="#" method="post" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" class="form-control" placeholder="Your name" autocomplete="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="your@email.com" autocomplete="email" required />
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject" class="form-control">
              <option value="">Select a topic…</option>
              <option value="general">General question</option>
              <option value="media">Media inquiry</option>
              <option value="sponsor">Donation / fundraising</option>
              <option value="tech">Website feedback</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" class="form-control" placeholder="Tell us what's on your mind…" required></textarea>
          </div>

          <div class="form-submit-row">
            <button type="submit" class="btn btn--primary">Send Message</button>
            <span class="response-note label">48-hour response time</span>
          </div>
        </form>
      </div>

      <aside class="contact-sidebar">

        <div class="sidebar-block">
          <span class="label sidebar-label">Quick links</span>
          <div class="quick-links">
            <a href="/participate" class="quick-link">
              <span class="ql-icon">🏡</span>
              <div class="ql-text">
                <strong>Porch, performer & volunteer signup</strong>
                <span>Opens mid-June 2026</span>
              </div>
              <span class="ql-arrow">→</span>
            </a>
            <a href="/schedule" class="quick-link">
              <span class="ql-icon">🎵</span>
              <div class="ql-text">
                <strong>View the schedule</strong>
                <span>Browse performers & porches</span>
              </div>
              <span class="ql-arrow">→</span>
            </a>
            <a href="https://givebutter.com/maplewoodporchfest" class="quick-link" target="_blank" rel="noopener noreferrer">
              <span class="ql-icon">💛</span>
              <div class="ql-text">
                <strong>Donate to Porchfest</strong>
                <span>via Givebutter</span>
              </div>
              <span class="ql-arrow">→</span>
            </a>
          </div>
        </div>

        <div class="sidebar-block">
          <span class="label sidebar-label">Follow</span>
          <div class="sidebar-socials">
            <a href="https://www.instagram.com/maplewood_porchfest/" target="_blank" rel="noopener noreferrer" class="social-row">
              <span class="social-abbr label">IG</span>
              <span>@maplewood_porchfest</span>
            </a>
            <a href="https://www.facebook.com/maplewoodporchfest" target="_blank" rel="noopener noreferrer" class="social-row">
              <span class="social-abbr label">FB</span>
              <span>maplewoodporchfest</span>
            </a>
            <a href="https://www.youtube.com/@maplewoodporchfest5068/videos" target="_blank" rel="noopener noreferrer" class="social-row">
              <span class="social-abbr label">YT</span>
              <span>@maplewoodporchfest5068</span>
            </a>
          </div>
        </div>

        <div class="sidebar-block">
          <span class="label sidebar-label">Presented by</span>
          <a href="http://www.maplewoodcommunitymusic.org/" target="_blank" rel="noopener noreferrer" class="org-link">
            Maplewood Community Music →
          </a>
          <span class="label sidebar-label" style="margin-top: 1.25rem;">Supported by</span>
          <a href="https://hnamaplewood.com/" target="_blank" rel="noopener noreferrer" class="org-link">
            Hilton Neighborhood Association →
          </a>
        </div>

      </aside>

    </div>
  </section>

</BaseLayout>

<style>
.contact-layout {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 5rem;
  align-items: start;
}

/* Form col */
.contact-heading {
  color: var(--ink);
  line-height: .9;
  margin-top: .4rem;
  margin-bottom: 1.25rem;
}

.contact-note {
  font-size: .9rem;
  color: rgba(12,11,9,.6);
  margin-bottom: 2rem;
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

.form-link {
  color: var(--red);
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 600;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

/* Override form-control colors for paper context */
.contact-form .form-control {
  border-color: rgba(12,11,9,.3);
  color: var(--ink);
}
.contact-form .form-control:focus {
  border-color: var(--red);
}
.contact-form .form-control::placeholder {
  color: rgba(12,11,9,.3);
  opacity: 1;
}
.contact-form .form-group label {
  color: rgba(12,11,9,.55);
}
.contact-form select.form-control option {
  background: var(--paper);
  color: var(--ink);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

.form-submit-row {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-top: .5rem;
}

.response-note {
  color: rgba(12,11,9,.35);
  opacity: 1;
}

/* Sidebar */
.sidebar-block {
  border-top: 2px solid rgba(12,11,9,.12);
  padding-top: 1.5rem;
  margin-bottom: 2rem;
  display: flex;
  flex-direction: column;
}

.sidebar-label {
  color: rgba(12,11,9,.35);
  opacity: 1;
  margin-bottom: 1rem;
  display: block;
}

.quick-links { display: flex; flex-direction: column; }

.quick-link {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .85rem 0;
  border-bottom: 1px solid rgba(12,11,9,.08);
  text-decoration: none;
  color: var(--ink);
  transition: background var(--transition), padding-left var(--transition);
}
.quick-link:last-child { border-bottom: none; }
.quick-link:hover { color: var(--red); }

.ql-icon { font-size: 1.1rem; flex-shrink: 0; }
.ql-text { flex: 1; }
.ql-text strong { display: block; font-size: .85rem; font-weight: 700; }
.ql-text span { font-size: .75rem; color: rgba(12,11,9,.45); display: block; }
.ql-arrow { font-size: .9rem; color: rgba(12,11,9,.3); transition: color var(--transition); }
.quick-link:hover .ql-arrow { color: var(--red); }

.sidebar-socials { display: flex; flex-direction: column; gap: .6rem; }

.social-row {
  display: flex;
  align-items: center;
  gap: .75rem;
  text-decoration: none;
  color: rgba(12,11,9,.65);
  font-size: .85rem;
  font-family: var(--font-body);
  transition: color var(--transition);
}
.social-row:hover { color: var(--red); }

.social-abbr {
  color: rgba(12,11,9,.3);
  opacity: 1;
  width: 24px;
  flex-shrink: 0;
}

.org-link {
  font-family: var(--font-body);
  font-size: .88rem;
  font-weight: 600;
  color: rgba(12,11,9,.7);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(12,11,9,.2);
  transition: color var(--transition), text-decoration-color var(--transition);
}
.org-link:hover {
  color: var(--red);
  text-decoration-color: var(--red);
}

@media (max-width: 900px) {
  .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
  .form-row { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .form-submit-row { flex-direction: column; align-items: flex-start; }
  .form-submit-row .btn { width: 100%; justify-content: center; }
}
</style>
