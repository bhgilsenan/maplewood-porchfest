---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = [
  {
    icon: "🏡",
    title: "Hilton Porch Signup",
    description:
      "Hilton neighbors, lend us your porch, front steps, stoop, yard, or driveway. Performers will be matched to your space based on size and suitability. You don't need to do anything except be a gracious host — we handle the rest.",
    details: [
      "Must be located in the Hilton neighborhood of Maplewood",
      "We'll match you with one or more performers",
      "You're welcome to set out chairs or blankets for guests",
      "No amplification required — we bring the gear",
    ],
    ctaLabel: "Sign Up Your Porch",
    color: "green",
  },
  {
    icon: "🎤",
    title: "Performer Signup",
    description:
      "Musicians, DJs, comedians, poets, dancers — perform to an appreciative community audience. This is a pass-the-hat event: there's no performance fee, but you keep everything in the hat.",
    details: [
      "Must perform a continuous set of at least 45 minutes",
      "All genres welcome — from classical to funk to hip-hop",
      "We'll provide a porch assignment and basic sound support",
      "Must be able to perform outdoors in summer weather",
    ],
    ctaLabel: "Sign Up to Perform",
    color: "gold",
  },
  {
    icon: "🍋",
    title: "Lemonade Stand & Volunteer",
    description:
      "Help make Porchfest happen! Run a lemonade stand along the route, volunteer during the event, or march in the Honk Parade at noon. No experience required — just enthusiasm.",
    details: [
      "Volunteer shifts: event day setup, during-event support, and cleanup",
      "Lemonade stands: we provide the stand, you provide the fun",
      "Honk Parade: gather at DeHart Community Center at 12 noon",
      "All ages welcome for volunteering",
    ],
    ctaLabel: "Sign Up to Volunteer",
    color: "coral",
  },
];
---

<BaseLayout
  title="Participate"
  description="Sign up to host a porch, perform, volunteer, or run a lemonade stand at Maplewood Porchfest 2026."
>

  <PageHero
    title="Participate"
    subtitle="Lend your porch. Share your music. Volunteer your afternoon. There are so many ways to be part of Porchfest."
  />

  <!-- STATUS BANNER -->
  <div class="status-banner" role="alert" aria-live="polite">
    <div class="container status-banner-inner">
      <span class="status-icon" aria-hidden="true">🗓️</span>
      <p>
        <strong>Registration opens mid-June.</strong>
        Check back soon — all signup forms will be active by June 15, 2026.
      </p>
    </div>
  </div>

  <!-- CATEGORIES -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">How to participate</h2>
      <div class="category-grid">
        {categories.map((cat) => (
          <div class:list={["category-card", `category-card--${cat.color}`]}>
            <div class="category-icon">
              {cat.color === "green" && (
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
              {cat.color === "gold" && (
                <svg width="44" height="44" viewBox="0 0 16 16" aria-hidden="true">
                  <path fill="currentColor" fill-rule="evenodd" d="m3.75 15.7l7.61-6.79c1.2.046 2.41-.389 3.33-1.3a4.466 4.466 0 0 0 0-6.31a4.466 4.466 0 0 0-6.31 0a4.43 4.43 0 0 0-1.3 3.33L.29 12.24a1.113 1.113 0 0 0 .044 1.53l1.89 1.89c.418.418 1.09.438 1.53.044zm6.83-7.43L7.71 5.4L6.49 6.77l2.72 2.72zm-2.11 1.89L5.83 7.52l-4.8 5.38a.117.117 0 0 0 .005.16l1.89 1.89a.117.117 0 0 0 .16.005l5.38-4.8zm-.395-5.81c.025-.854.363-1.7 1.01-2.35a3.47 3.47 0 0 1 4.9 0a3.47 3.47 0 0 1 0 4.9a3.42 3.42 0 0 1-2.35 1.01l-3.57-3.57z" clip-rule="evenodd"/>
                </svg>
              )}
              {cat.color === "coral" && (
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
            </div>
            <h3 class="category-title">{cat.title}</h3>
            <p class="category-desc">{cat.description}</p>
            <ul class="category-details">
              {cat.details.map((d) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {d}
                </li>
              ))}
            </ul>
            <button
              class:list={["btn", cat.color === "gold" ? "btn--gold" : cat.color === "coral" ? "btn--primary" : "btn--green", "category-cta"]}
              disabled
              aria-label={`${cat.ctaLabel} — opens mid-June`}
              title="Registration opens mid-June"
            >
              {cat.ctaLabel}
            </button>
            <p class="category-cta-note">Opens mid-June</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--cream-dark faq-section">
    <div class="container faq-inner">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h4>Is there a cost to participate?</h4>
          <p>No. Porchfest is entirely free — to attend, to perform, and to volunteer. Performers pass the hat; tips go directly to the artists.</p>
        </div>
        <div class="faq-item">
          <h4>Do I need to be a professional musician?</h4>
          <p>Absolutely not. We welcome performers of all skill levels. Porchfest is about community, not credentials.</p>
        </div>
        <div class="faq-item">
          <h4>What if it rains?</h4>
          <p>If rain is forecast, we'll shift to the rain date: Monday, September 7th. We'll announce changes via Instagram and Facebook.</p>
        </div>
        <div class="faq-item">
          <h4>Can I perform solo?</h4>
          <p>Yes — solo artists, duos, trios, and full bands are all welcome. The 45-minute minimum set applies to all performers.</p>
        </div>
        <div class="faq-item">
          <h4>What neighborhoods are eligible for porch hosting?</h4>
          <p>Porchfest takes place in the Hilton neighborhood of Maplewood. If you're unsure whether your address qualifies, include your address in the signup form.</p>
        </div>
        <div class="faq-item">
          <h4>How are performers matched to porches?</h4>
          <p>Organizers hand-match performers to porches based on musical style, porch size, and acoustics. You'll receive your assignment by mid-August.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="section section--dark">
    <div class="container closing-cta">
      <h2 style="color: var(--cream);">Questions?</h2>
      <p style="color: rgba(250,246,238,.75); max-width: 50ch; margin-top: .75rem;">
        Can't find what you're looking for? Reach out via the contact page —
        we try to respond within 48 hours.
      </p>
      <a href={`${base}/contact`} class="btn btn--gold" style="margin-top: 1.5rem;">Get in Touch</a>
    </div>
  </section>

</BaseLayout>

<style>
/* Status Banner */
.status-banner {
  background: var(--gold);
  padding: 1rem 0;
  margin-top: 2rem;
}
.status-banner-inner {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.status-icon { font-size: 1.25rem; flex-shrink: 0; }
.status-banner p { font-size: .95rem; max-width: 100%; color: var(--charcoal); }

/* Section heading */
.section-heading { margin-bottom: 2.5rem; }

/* Category Grid */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}


.category-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2.25rem 2rem;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: box-shadow var(--transition);
}
.category-card:hover {
  box-shadow: var(--shadow-md);
}

.category-icon { line-height: 0; color: var(--gold); }
.category-card--green .category-icon { color: var(--green); }
.category-card--gold  .category-icon { color: var(--gold); }
.category-card--coral .category-icon { color: var(--coral); }
.category-title {
  font-size: 1.3rem;
  padding-bottom: .6rem;
  position: relative;
}
.category-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 36px;
  height: 3px;
  border-radius: 2px;
  background: var(--gold);
}
.category-card--green .category-title::after { background: var(--green); }
.category-card--gold  .category-title::after { background: var(--gold); }
.category-card--coral .category-title::after { background: var(--coral); }
.category-desc { color: var(--gray); font-size: .95rem; max-width: 100%; }

.category-details {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: .6rem;
  flex: 1;
}

.category-details li {
  display: flex;
  gap: .6rem;
  font-size: .88rem;
  color: var(--charcoal);
  align-items: flex-start;
}

.category-details li svg {
  flex-shrink: 0;
  color: var(--green);
  margin-top: 2px;
}
.category-card--gold .category-details li svg { color: var(--gold-dark); }
.category-card--coral .category-details li svg { color: var(--coral); }

.category-cta {
  margin-top: auto;
  width: 100%;
  justify-content: center;
  opacity: .55;
  cursor: not-allowed;
}
.category-cta:hover { transform: none !important; }

.category-cta-note {
  text-align: center;
  font-size: .8rem;
  color: var(--gray-light);
  margin-top: -.5rem;
}

/* FAQ */
.faq-inner { max-width: 900px; }
.faq-inner h2 { margin-bottom: 2rem; }
.faq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}
.faq-item h4 {
  font-size: 1rem;
  margin-bottom: .5rem;
  color: var(--charcoal);
}
.faq-item p { font-size: .9rem; color: var(--gray); max-width: 100%; }

/* Closing CTA */
.closing-cta { text-align: center; }
.closing-cta p { margin-inline: auto; }

/* Responsive */
@media (max-width: 900px) {
  .category-grid { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; }
  .faq-grid { grid-template-columns: 1fr; }
}
</style>
