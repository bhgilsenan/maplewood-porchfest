---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const categories = [
  {
    num: "01",
    icon: "🏡",
    title: "Porch",
    fullTitle: "Hilton Porch Signup",
    description: "Hilton neighbors, lend us your porch, front steps, stoop, yard, or driveway. We match performers to your space. You just need to show up and be a gracious host.",
    details: [
      "Must be located in the Hilton neighborhood of Maplewood",
      "We match you with one or more performers",
      "No amplification required — we handle sound",
      "Chairs and blankets for guests are a nice touch",
    ],
    ctaLabel: "Sign Up Your Porch",
    accent: "sage",
  },
  {
    num: "02",
    icon: "🎤",
    title: "Perform",
    fullTitle: "Performer Signup",
    description: "Musicians, DJs, comedians, poets, dancers — perform to an appreciative community audience. Pass-the-hat: no fee, but you keep everything in the hat.",
    details: [
      "Minimum 45-minute continuous set required",
      "All genres welcome — classical to hip-hop",
      "Basic sound support provided",
      "Must be able to perform outdoors in summer weather",
    ],
    ctaLabel: "Sign Up to Perform",
    accent: "red",
  },
  {
    num: "03",
    icon: "🍋",
    title: "Volunteer",
    fullTitle: "Lemonade Stand & Volunteer",
    description: "Help make Porchfest happen. Run a lemonade stand along the route, volunteer on event day, or march in the Honk Parade at noon. No experience needed.",
    details: [
      "Event day setup, support, and cleanup shifts",
      "Lemonade stand: we provide the stand",
      "Honk Parade: DeHart Community Center, 12 noon",
      "All ages welcome",
    ],
    ctaLabel: "Sign Up to Volunteer",
    accent: "yellow",
  },
];

const faqs = [
  { q: "Is there a cost to participate?", a: "No. Porchfest is entirely free — to attend, to perform, and to volunteer. Performers pass the hat; tips go directly to the artists." },
  { q: "Do I need to be a professional musician?", a: "Absolutely not. We welcome performers of all skill levels. Porchfest is about community, not credentials." },
  { q: "What if it rains?", a: "We shift to the rain date: Monday, September 7th. Watch our Instagram and Facebook for updates." },
  { q: "Can I perform solo?", a: "Yes — solos, duos, trios, full bands. The 45-minute minimum applies to everyone." },
  { q: "What neighborhoods can host a porch?", a: "Porchfest is in the Hilton neighborhood of Maplewood. Include your address in the signup if you're unsure." },
  { q: "How are performers matched to porches?", a: "Organizers hand-match by musical style, porch size, and acoustics. Assignments go out mid-August." },
];
---

<BaseLayout
  title="Participate"
  description="Sign up to host a porch, perform, volunteer, or run a lemonade stand at Maplewood Porchfest 2026."
>

  <PageHero
    title="Participate"
    subtitle="There are three ways in. Pick one — or all three."
  />

  <!-- Status banner -->
  <div class="status-banner">
    <div class="container status-inner">
      <span class="label" style="color: var(--yellow); opacity: 1;">Registration</span>
      <p>All signup forms open mid-June 2026. Check back soon — or follow <a href="https://www.instagram.com/maplewood_porchfest/" target="_blank" rel="noopener noreferrer" class="banner-link">@maplewood_porchfest</a> for the announcement.</p>
    </div>
  </div>

  <!-- Participation options -->
  <section class="section section--paper">
    <div class="container">
      <div class="categories-grid">
        {categories.map(cat => (
          <div class:list={["cat-card", `cat-card--${cat.accent}`]}>
            <div class="cat-header">
              <span class="cat-num label">{cat.num}</span>
              <span class="cat-icon">{cat.icon}</span>
            </div>
            <h2 class="cat-title">{cat.title}</h2>
            <p class="cat-full-title">{cat.fullTitle}</p>
            <div class="cat-rule"></div>
            <p class="cat-desc">{cat.description}</p>
            <ul class="cat-details">
              {cat.details.map(d => (
                <li>
                  <span class="detail-marker" aria-hidden="true">—</span>
                  {d}
                </li>
              ))}
            </ul>
            <div class="cat-footer">
              <button
                class:list={[
                  "btn",
                  cat.accent === "red" ? "btn--primary" :
                  cat.accent === "yellow" ? "btn--yellow" : "btn--sage",
                  "cat-cta"
                ]}
                disabled
                title="Registration opens mid-June"
              >
                {cat.ctaLabel}
              </button>
              <span class="cat-cta-note label">Opens mid-June</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--ink">
    <div class="container faq-layout">
      <div class="faq-left">
        <span class="eyebrow" style="color: var(--yellow); opacity: 1;">FAQ</span>
        <h2>Questions</h2>
      </div>
      <div class="faq-right">
        {faqs.map((item, i) => (
          <div class="faq-item">
            <div class="faq-q-row">
              <span class="faq-num label">{String(i + 1).padStart(2, '0')}</span>
              <h4 class="faq-q">{item.q}</h4>
            </div>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--red" style="padding-block: 3rem;">
    <div class="container closing-cta">
      <h2>Still have questions?</h2>
      <p>Reach out via the contact page. We respond within 48 hours.</p>
      <a href="/contact" class="btn btn--outline-dark">Get in Touch</a>
    </div>
  </section>

</BaseLayout>

<style>
/* Status banner */
.status-banner {
  background: var(--ink-mid);
  border-bottom: 1px solid rgba(239,231,210,.1);
  padding: 1.1rem 0;
}
.status-inner {
  display: flex;
  align-items: baseline;
  gap: 1.25rem;
  flex-wrap: wrap;
}
.status-inner p {
  font-size: .88rem;
  color: rgba(239,231,210,.65);
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}
.banner-link {
  color: var(--yellow);
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 700;
}

/* Categories */
.categories-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 2px solid var(--ink);
}

.cat-card {
  padding: 2.5rem 2rem;
  border-right: 2px solid var(--ink);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.cat-card:last-child { border-right: none; }

.cat-card--red   { background: var(--paper); }
.cat-card--sage  { background: var(--paper-mid); }
.cat-card--yellow { background: var(--paper); }

.cat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cat-num { color: rgba(12,11,9,.3); opacity: 1; }
.cat-icon { font-size: 2rem; }

.cat-title {
  font-size: clamp(3rem, 5vw, 4rem);
  color: var(--ink);
  line-height: .9;
  margin-bottom: -.5rem;
}

.cat-full-title {
  font-family: var(--font-body);
  font-size: .8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: rgba(12,11,9,.45);
  max-width: 100%;
  font-style: normal;
}

.cat-rule {
  height: 2px;
  width: 32px;
}
.cat-card--red   .cat-rule { background: var(--red); }
.cat-card--sage  .cat-rule { background: var(--sage); }
.cat-card--yellow .cat-rule { background: var(--yellow-dark); }

.cat-desc {
  color: rgba(12,11,9,.7);
  font-size: .9rem;
  max-width: 100%;
}

.cat-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: .55rem;
}

.cat-details li {
  display: flex;
  gap: .6rem;
  font-size: .83rem;
  color: rgba(12,11,9,.65);
  line-height: 1.4;
}

.detail-marker {
  color: rgba(12,11,9,.3);
  flex-shrink: 0;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

.cat-footer {
  display: flex;
  flex-direction: column;
  gap: .5rem;
  margin-top: .5rem;
}

.cat-cta {
  opacity: .5;
  cursor: not-allowed;
  width: 100%;
  justify-content: center;
}
.cat-cta:hover { transform: none; }

.cat-cta-note {
  color: rgba(12,11,9,.35);
  text-align: center;
  opacity: 1;
}

/* FAQ */
.faq-layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}

.faq-left h2 { line-height: .9; margin-top: .4rem; }

.faq-right {
  display: flex;
  flex-direction: column;
}

.faq-item {
  padding: 1.5rem 0;
  border-bottom: 1px solid rgba(239,231,210,.1);
}
.faq-item:first-child { border-top: 1px solid rgba(239,231,210,.1); }

.faq-q-row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: .6rem;
}
.faq-num { color: rgba(239,231,210,.3); opacity: 1; }
.faq-q {
  font-family: var(--font-body);
  font-weight: 700;
  font-style: normal;
  font-size: .95rem;
  text-transform: none;
  letter-spacing: 0;
  color: var(--paper);
}
.faq-a {
  font-size: .88rem;
  color: rgba(239,231,210,.6);
  padding-left: calc(1.5rem + .7rem);
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

/* Closing CTA */
.closing-cta {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.closing-cta h2 { color: var(--ink); flex-shrink: 0; }
.closing-cta p {
  color: rgba(12,11,9,.65);
  flex: 1;
  min-width: 200px;
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

@media (max-width: 900px) {
  .categories-grid { grid-template-columns: 1fr; border-bottom: none; }
  .cat-card { border-right: none; border-bottom: 2px solid var(--ink); }
  .faq-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .faq-left { display: flex; align-items: baseline; gap: 1.5rem; }
}
</style>
