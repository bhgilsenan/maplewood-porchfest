---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { title, subtitle, align = "left" } = Astro.props;
---

<section class:list={["page-hero", `page-hero--${align}`]}>
  <div class="page-hero-rule page-hero-rule--top"></div>
  <div class="container page-hero-inner">
    <span class="page-hero-eyebrow label">Maplewood Porchfest · 2026</span>
    <h1 class="page-hero-title">{title}</h1>
    {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
    <slot />
  </div>
  <div class="page-hero-rule page-hero-rule--bottom"></div>
</section>

<style>
.page-hero {
  background: var(--ink);
  color: var(--paper);
  padding: 7rem 0 4.5rem;
  position: relative;
  overflow: hidden;
}

/* Subtle halftone-like accent behind title */
.page-hero::before {
  content: '';
  position: absolute;
  right: -5%;
  top: 50%;
  transform: translateY(-50%);
  width: 55%;
  aspect-ratio: 1;
  background: radial-gradient(circle, rgba(232,73,42,.08) 0%, transparent 70%);
  pointer-events: none;
}

.page-hero-rule--top {
  position: absolute;
  top: 64px; /* sits at bottom of header */
  left: 0; right: 0;
  height: 3px;
  background: var(--red);
}

.page-hero-rule--bottom {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  height: 1px;
  background: rgba(239,231,210,.12);
}

.page-hero-inner {
  position: relative;
  z-index: 1;
}

.page-hero--center .page-hero-inner { text-align: center; }
.page-hero--center .page-hero-inner p { margin-inline: auto; }

.page-hero-eyebrow {
  display: block;
  margin-bottom: 1rem;
  color: rgba(239,231,210,.45);
}

.page-hero-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  text-transform: uppercase;
  font-size: clamp(3.5rem, 8vw, 7rem);
  color: var(--paper);
  line-height: .95;
  letter-spacing: -.02em;
  margin-bottom: 1.25rem;
}

.page-hero-subtitle {
  font-family: var(--font-body);
  font-size: clamp(.95rem, 1.8vw, 1.1rem);
  color: rgba(239,231,210,.65);
  max-width: 58ch;
  line-height: 1.6;
  font-weight: 400;
  text-transform: none;
  font-style: normal;
  letter-spacing: 0;
}
</style>
