---
const navLinks = [
  { href: "/",           label: "Home" },
  { href: "/participate", label: "Participate" },
  { href: "/schedule",   label: "Schedule" },
  { href: "/#about",     label: "About" },
  { href: "/photos",     label: "Photos" },
  { href: "/contact",    label: "Contact" },
];

const socialLinks = [
  { href: "https://www.instagram.com/maplewood_porchfest/", label: "Instagram", abbr: "IG" },
  { href: "https://www.facebook.com/maplewoodporchfest",    label: "Facebook",  abbr: "FB" },
  { href: "https://www.youtube.com/@maplewoodporchfest5068/videos", label: "YouTube", abbr: "YT" },
];
---

<footer class="site-footer">

  <!-- Top rule -->
  <div class="footer-top-rule"></div>

  <!-- Newsletter strip -->
  <div class="footer-newsletter-strip">
    <div class="container newsletter-inner">
      <div class="newsletter-text">
        <span class="label">Stay in the loop</span>
        <p>Updates on performers, schedule, and rain dates — before everyone else.</p>
      </div>
      <form class="newsletter-form" action="#" method="post">
        <label for="footer-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="footer-email"
          name="email"
          class="newsletter-input"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
        <button type="submit" class="btn btn--primary newsletter-btn">Subscribe</button>
      </form>
    </div>
  </div>

  <div class="footer-rule"></div>

  <!-- Main footer body -->
  <div class="footer-body">
    <div class="container footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-small">Maplewood</span>
          <span class="footer-logo-large">Porchfest</span>
        </a>
        <p class="footer-description">
          Free · All-volunteer · Commercial-free<br/>
          Labor Day Sunday · Hilton Neighborhood<br/>
          Maplewood, NJ
        </p>
        <div class="footer-social">
          {socialLinks.map(s => (
            <a
              href={s.href}
              class="social-tag"
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              {s.abbr}
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <span class="label footer-nav-label">Pages</span>
        <ul class="footer-nav-list">
          {navLinks.map(link => (
            <li><a href={link.href} class="footer-nav-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Partners -->
      <div class="footer-partners">
        <span class="label footer-nav-label">Presented by</span>
        <a href="http://www.maplewoodcommunitymusic.org/" target="_blank" rel="noopener noreferrer" class="partner-link">
          Maplewood Community Music
        </a>

        <span class="label footer-nav-label" style="margin-top: 1.5rem;">Supported by</span>
        <a href="https://hnamaplewood.com/" target="_blank" rel="noopener noreferrer" class="partner-link">
          Hilton Neighborhood Association
        </a>

        <span class="label footer-nav-label" style="margin-top: 1.5rem;">Donate</span>
        <a href="https://givebutter.com/maplewoodporchfest" target="_blank" rel="noopener noreferrer" class="partner-link partner-link--cta">
          givebutter.com/maplewoodporchfest →
        </a>
      </div>

    </div>
  </div>

  <div class="footer-rule"></div>

  <!-- Colophon -->
  <div class="footer-colophon">
    <div class="container colophon-inner">
      <p>&copy; 2026 Maplewood Community Music</p>
      <p>Photos: John Munson · Tom Malee · George Burrus · Steve LeBlanc · Tracy Sham · community volunteers</p>
    </div>
  </div>

</footer>

<style>
.site-footer {
  background: var(--ink);
  color: var(--paper);
  margin-top: auto;
}

.footer-top-rule {
  height: 3px;
  background: var(--red);
}

/* Newsletter strip */
.footer-newsletter-strip {
  background: var(--ink-mid);
  padding: 2rem 0;
}

.newsletter-inner {
  display: flex;
  align-items: center;
  gap: 3rem;
  flex-wrap: wrap;
}

.newsletter-text .label {
  color: var(--yellow);
  margin-bottom: .35rem;
  display: block;
  opacity: 1;
}
.newsletter-text p {
  font-size: .88rem;
  color: rgba(239,231,210,.6);
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

.newsletter-form {
  display: flex;
  gap: 0;
  flex: 1;
  min-width: 280px;
}

.newsletter-input {
  flex: 1;
  padding: .6rem .9rem;
  background: transparent;
  border: 2px solid rgba(239,231,210,.25);
  border-right: none;
  color: var(--paper);
  font-family: var(--font-body);
  font-size: .9rem;
  transition: border-color var(--transition);
}
.newsletter-input::placeholder { color: rgba(239,231,210,.3); }
.newsletter-input:focus {
  outline: none;
  border-color: var(--red);
}

.newsletter-btn {
  flex-shrink: 0;
  font-size: .78rem;
  padding: .6rem 1.2rem;
}

/* Footer rule */
.footer-rule {
  height: 1px;
  background: rgba(239,231,210,.1);
}

/* Footer body */
.footer-body { padding: 3rem 0; }

.footer-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1.4fr;
  gap: 3rem;
}

/* Brand */
.footer-logo {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  margin-bottom: 1.25rem;
  line-height: 1;
}

.footer-logo-small {
  font-family: var(--font-body);
  font-size: .55rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .22em;
  color: rgba(239,231,210,.4);
}

.footer-logo-large {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  text-transform: uppercase;
  font-size: 2rem;
  color: var(--paper);
}

.footer-description {
  font-size: .82rem;
  color: rgba(239,231,210,.45);
  line-height: 1.7;
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  margin-bottom: 1.25rem;
}

.footer-social {
  display: flex;
  gap: .5rem;
}

.social-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 28px;
  border: 1.5px solid rgba(239,231,210,.2);
  font-family: var(--font-body);
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .06em;
  color: rgba(239,231,210,.5);
  text-decoration: none;
  transition: border-color var(--transition), color var(--transition), background var(--transition);
}
.social-tag:hover {
  border-color: var(--red);
  color: var(--paper);
  background: var(--red);
}

/* Nav */
.footer-nav-label {
  display: block;
  color: rgba(239,231,210,.35);
  margin-bottom: .9rem;
}

.footer-nav-list {
  display: flex;
  flex-direction: column;
  gap: .6rem;
}

.footer-nav-link {
  font-family: var(--font-body);
  font-size: .88rem;
  font-weight: 600;
  color: rgba(239,231,210,.6);
  text-decoration: none;
  transition: color var(--transition);
}
.footer-nav-link:hover { color: var(--paper); }

/* Partners */
.footer-partners {
  display: flex;
  flex-direction: column;
}

.partner-link {
  font-family: var(--font-body);
  font-size: .88rem;
  font-weight: 600;
  color: rgba(239,231,210,.65);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(239,231,210,.2);
  transition: color var(--transition), text-decoration-color var(--transition);
  margin-bottom: .25rem;
}
.partner-link:hover {
  color: var(--paper);
  text-decoration-color: var(--red);
}

.partner-link--cta {
  color: var(--yellow);
  text-decoration-color: rgba(240,216,74,.3);
}
.partner-link--cta:hover {
  color: var(--yellow);
  text-decoration-color: var(--yellow);
}

/* Colophon */
.footer-colophon { padding: 1.25rem 0; }

.colophon-inner {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem 2rem;
  justify-content: space-between;
}

.colophon-inner p {
  font-size: .72rem;
  color: rgba(239,231,210,.3);
  max-width: 100%;
  font-style: normal;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); border: 0;
}

@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 600px) {
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  .newsletter-inner { flex-direction: column; gap: 1.25rem; }
  .newsletter-form { flex-direction: column; min-width: unset; }
  .newsletter-input { border-right: 2px solid rgba(239,231,210,.25); }
  .newsletter-input:focus { border-color: var(--red); }
  .colophon-inner { flex-direction: column; gap: .35rem; }
}
</style>
