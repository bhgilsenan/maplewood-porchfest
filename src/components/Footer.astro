---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: "/",           label: "Home" },
  { href: "/participate", label: "Participate" },
  { href: "/schedule",   label: "Schedule" },
  { href: "/#about",     label: "About" },
  { href: "/photos",     label: "Photos" },
  { href: "/contact",    label: "Contact" },
];

const socialLinks = [
  {
    href: "https://www.instagram.com/maplewood_porchfest/",
    label: "Instagram",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`
  },
  {
    href: "https://www.facebook.com/maplewoodporchfest",
    label: "Facebook",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`
  },
  {
    href: "https://www.youtube.com/@maplewoodporchfest5068/videos",
    label: "YouTube",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.94C18.88 4 12 4 12 4s-6.88 0-8.6.48A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.94 1.94C5.12 20 12 20 12 20s6.88 0 8.6-.48a2.78 2.78 0 0 0 1.94-1.94A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>`
  },
];
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container footer-top-inner">
      <!-- Branding -->
      <div class="footer-brand">
        <a href={base + "/"} class="footer-logo-text" aria-label="Maplewood Porchfest home">
          Maplewood<br/><em>Porchfest</em>
        </a>
        <p class="footer-tagline">Free · All-volunteer · Commercial-free<br/>Labor Day Sunday · Hilton Neighborhood · Maplewood, NJ</p>
        <div class="footer-social">
          {socialLinks.map(s => (
            <a href={s.href} class="social-link" aria-label={s.label} target="_blank" rel="noopener noreferrer">
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <h4 class="footer-nav-heading">Pages</h4>
        <ul class="footer-nav-list">
          {navLinks.map(link => (
            <li><a href={base + link.href} class="footer-nav-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Newsletter -->
      <div class="footer-newsletter">
        <h4 class="footer-nav-heading">Stay in the loop</h4>
        <p>Get updates on performers, schedule, and events before the crowd.</p>
        <form class="newsletter-form" action="#" method="post" aria-label="Newsletter signup">
          <div class="newsletter-fields">
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="footer-email"
              name="email"
              placeholder="your@email.com"
              class="newsletter-input"
              autocomplete="email"
              required
            />
            <button type="submit" class="btn btn--gold newsletter-btn">Subscribe</button>
          </div>
          <p class="newsletter-disclaimer">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="copyright">&copy; 2026 Maplewood Community Music</p>
      <p class="footer-credits">
        Photos: John Munson, Tom Melee, Gregory Burrus, Scott Kettner, Steve LeBlanc, Tracy Sham &amp; community volunteers.
      </p>
      <div class="footer-partners">
        <span>Presented by <a href="http://www.maplewoodcommunitymusic.org/" target="_blank" rel="noopener noreferrer">Maplewood Community Music</a></span>
        <span>Supported by <a href="https://hnamaplewood.com/" target="_blank" rel="noopener noreferrer">Hilton Neighborhood Assoc.</a></span>
      </div>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--charcoal);
  color: var(--cream);
  margin-top: auto;
}

.footer-top { padding: 4rem 0 3rem; }

.footer-top-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1.5fr;
  gap: 3rem;
}

/* Brand */
.footer-logo-text {
  display: inline-block;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.4rem;
  line-height: 1.2;
  color: var(--cream);
  text-decoration: none;
  margin-bottom: .75rem;
}
.footer-logo-text em {
  font-style: italic;
  color: var(--gold-light);
  font-size: 1.6rem;
}

.footer-tagline {
  font-size: .85rem;
  color: rgba(250,246,238,.65);
  line-height: 1.6;
  margin-bottom: 1.25rem;
  max-width: 100%;
}

.footer-social {
  display: flex;
  gap: .75rem;
}

.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,.08);
  color: var(--cream);
  transition: background 150ms, color 150ms, transform 150ms;
}
.social-link:hover {
  background: var(--gold);
  color: var(--charcoal);
  transform: translateY(-2px);
}
.social-link :global(svg) { width: 18px; height: 18px; }

/* Nav */
.footer-nav-heading {
  font-family: var(--font-display);
  font-size: .85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--gold-light);
  margin-bottom: 1rem;
}

.footer-nav-list { display: flex; flex-direction: column; gap: .5rem; }

.footer-nav-link {
  color: rgba(250,246,238,.75);
  font-size: .9rem;
  text-decoration: none;
  transition: color 150ms;
}
.footer-nav-link:hover { color: var(--cream); }

/* Newsletter */
.footer-newsletter p {
  font-size: .9rem;
  color: rgba(250,246,238,.75);
  margin-bottom: 1rem;
  max-width: 100%;
}

.newsletter-fields {
  display: flex;
  gap: .5rem;
}

.newsletter-input {
  flex: 1;
  min-width: 0;
  padding: .6rem 1rem;
  border: 1.5px solid rgba(255,255,255,.2);
  border-radius: 50px;
  background: rgba(255,255,255,.07);
  color: var(--cream);
  font-family: var(--font-body);
  font-size: .9rem;
  transition: border-color 150ms, background 150ms;
}
.newsletter-input::placeholder { color: rgba(250,246,238,.4); }
.newsletter-input:focus {
  outline: none;
  border-color: var(--gold);
  background: rgba(255,255,255,.1);
}

.newsletter-btn {
  flex-shrink: 0;
  padding: .6rem 1.25rem;
  font-size: .85rem;
  border-radius: 50px;
}

.newsletter-disclaimer {
  font-size: .75rem;
  color: rgba(250,246,238,.4);
  margin-top: .5rem;
  max-width: 100%;
}

/* Bottom */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.08);
  padding: 1.25rem 0;
}

.footer-bottom-inner {
  display: flex;
  flex-wrap: wrap;
  gap: .75rem 2rem;
  align-items: center;
  justify-content: space-between;
}

.copyright {
  font-size: .8rem;
  color: rgba(250,246,238,.5);
  max-width: 100%;
}

.footer-credits {
  font-size: .8rem;
  color: rgba(250,246,238,.4);
  max-width: 100%;
}

.footer-partners {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: .8rem;
  color: rgba(250,246,238,.5);
}
.footer-partners a {
  color: var(--gold-light);
  text-decoration: none;
  transition: color 150ms;
}
.footer-partners a:hover { color: var(--gold); }

.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

/* Responsive */
@media (max-width: 900px) {
  .footer-top-inner {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 600px) {
  .footer-top-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .footer-bottom-inner {
    flex-direction: column;
    align-items: flex-start;
    gap: .5rem;
  }
  .newsletter-fields { flex-direction: column; }
  .newsletter-btn { width: 100%; justify-content: center; }
}
</style>
