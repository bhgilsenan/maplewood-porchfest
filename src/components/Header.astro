---
const navLinks = [
  { href: "/",           label: "Home" },
  { href: "/participate", label: "Participate" },
  { href: "/schedule",   label: "Schedule" },
  { href: "/#about",     label: "About" },
  { href: "/photos",     label: "Photos" },
  { href: "/contact",    label: "Contact" },
];

const pathname = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner container">

    <a href="/" class="header-logo" aria-label="Maplewood Porchfest home">
      <span class="logo-line-1">Maplewood</span>
      <span class="logo-line-2">Porchfest</span>
    </a>

    <nav class="header-nav" id="header-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={["nav-link", { "nav-link--active": isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/participate" class="header-cta btn btn--primary no-mobile">
      Get Involved
    </a>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="header-nav"
    >
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

  </div>
</header>

<script>
  const btn   = document.getElementById("hamburger")!;
  const nav   = document.getElementById("header-nav")!;
  const header = document.getElementById("site-header")!;

  btn.addEventListener("click", () => {
    const open = nav.classList.toggle("is-open");
    btn.setAttribute("aria-expanded", String(open));
    btn.classList.toggle("is-open", open);
    document.body.classList.toggle("nav-open", open);
  });

  document.addEventListener("click", e => {
    if (!header.contains(e.target as Node) && nav.classList.contains("is-open")) {
      nav.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      btn.classList.remove("is-open");
      document.body.classList.remove("nav-open");
    }
  });

  nav.querySelectorAll(".nav-link").forEach(link => {
    link.addEventListener("click", () => {
      nav.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      btn.classList.remove("is-open");
      document.body.classList.remove("nav-open");
    });
  });

  window.addEventListener("scroll", () => {
    header.classList.toggle("is-scrolled", window.scrollY > 10);
  }, { passive: true });
</script>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: var(--ink);
  border-bottom: 2px solid rgba(239,231,210,.12);
  transition: border-color 200ms;
}

.site-header.is-scrolled {
  border-bottom-color: rgba(239,231,210,.22);
}

.header-inner {
  display: flex;
  align-items: center;
  height: 64px;
  gap: 2rem;
}

/* Logo */
.header-logo {
  display: flex;
  flex-direction: column;
  line-height: 1;
  text-decoration: none;
  flex-shrink: 0;
  gap: 0;
}

.logo-line-1 {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: .6rem;
  text-transform: uppercase;
  letter-spacing: .22em;
  color: rgba(239,231,210,.5);
}

.logo-line-2 {
  font-family: var(--font-display);
  font-weight: 900;
  font-style: italic;
  text-transform: uppercase;
  font-size: 1.45rem;
  color: var(--paper);
  letter-spacing: .01em;
  line-height: 1;
}

/* Nav */
.header-nav { flex: 1; display: flex; justify-content: center; }

.nav-list {
  display: flex;
  align-items: center;
  gap: 0;
}

.nav-link {
  display: block;
  padding: .4rem .7rem;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: .72rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: rgba(239,231,210,.55);
  text-decoration: none;
  transition: color var(--transition);
  white-space: nowrap;
}

.nav-link:hover { color: var(--paper); }

.nav-link--active {
  color: var(--paper);
}

.nav-link--active::after {
  content: '';
  display: block;
  height: 2px;
  background: var(--red);
  margin-top: 2px;
}

/* Header CTA */
.header-cta {
  margin-left: auto;
  flex-shrink: 0;
  font-size: .75rem;
  padding: .45rem 1rem;
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
  width: 32px;
  height: 32px;
  cursor: pointer;
  flex-shrink: 0;
  margin-left: auto;
}

.bar {
  display: block;
  width: 100%;
  height: 2px;
  background: var(--paper);
  transition: transform 200ms, opacity 200ms, width 200ms;
  transform-origin: left center;
}

.hamburger.is-open .bar:nth-child(1) { transform: rotate(45deg) translateY(-1px); }
.hamburger.is-open .bar:nth-child(2) { transform: rotate(-45deg) translateY(1px); }

/* Mobile nav */
@media (max-width: 860px) {
  .no-mobile { display: none; }
  .hamburger { display: flex; }

  .header-nav {
    display: none;
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: var(--ink-mid);
    border-bottom: 2px solid rgba(239,231,210,.15);
    padding: 1rem 1.5rem 1.5rem;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
  }

  .header-nav.is-open { display: flex; }

  .nav-list {
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .nav-link {
    font-size: .85rem;
    padding: .65rem 0;
    border-bottom: 1px solid rgba(239,231,210,.08);
    width: 100%;
  }

  .nav-link--active::after { display: none; }
  .nav-link--active { color: var(--yellow); }
}
</style>
